{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Fan-Made",
  "version": "1.0.0",
  "identifier": "com.claudefanmade.app",
  "build": {
    "frontendDist": "https://claude-ai-8iev.onrender.com"
  },
  "app": {
    "windows": [
      {
        "title": "Claude Fan-Made",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "dangerousRemoteDomainIpcAccess": [
        {
          "domain": "claude-ai-8iev.onrender.com",
          "windows": ["main"],
          "plugins": [],
          "enableTauriApi": true
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}